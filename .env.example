# ========================================
# VOX-BRIDGE - Environment Variables
# ========================================

# Server
PORT=8080
NODE_ENV=development

# ========================================
# VOXGRID - Global TURN Infrastructure
# ========================================
# Para conexões intercontinentais (Brasil ↔ África, etc)
# Crie conta em https://www.metered.ca e obtenha API keys

# Metered.ca Global (RECOMENDADO)
METERED_API_KEY=
METERED_API_SECRET=

# TURN próprio (alternativa para escala)
TURN_SECRET=
TURN_URLS=

# ========================================
# WebRTC - Frontend Configuration
# ========================================
# Estas variáveis devem ser configuradas no frontend/.env.local

# STUN Server (opcional - padrão: Google STUN)
# NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302

# TURN Server (opcional - necessário para NAT restritivo)
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=username
# NEXT_PUBLIC_TURN_CREDENTIAL=credential

# ========================================
# PROST-QS Integration (Governance Layer)
# ========================================
# Obtenha as credenciais via Admin Panel do PROST-QS
# NUNCA commitar valores reais no git!

# Desenvolvimento local
# PROSTQS_URL=http://localhost:8080

# Producao (Oracle Cloud VM)
PROSTQS_URL=https://api.prostqs.com.br
PROSTQS_APP_ID=4fb16e2f-f8f0-425d-84f0-2ef3176bba43
PROSTQS_APP_KEY=
PROSTQS_APP_SECRET=
PROSTQS_DEBUG=false
